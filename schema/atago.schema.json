{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nao1215/atago/schema/atago.schema.json",
  "title": "atago",
  "description": "Schema for atago black-box behavior spec files (*.atago.yaml). See doc/design/schema.md.",
  "type": "object",
  "required": ["version", "suite", "scenarios"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "enum": ["1", 1],
      "description": "Spec format version. Write \"1\" (quoted); a bare 1 is accepted for convenience \u2014 the loader coerces it to \"1\"."
    },
    "suite": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "env": {
          "description": "Environment exported to every scenario, setup, and teardown step (a scenario's own env wins per key).",
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "setup": {
          "description": "Steps run ONCE before any scenario, in order, inside the ${suitedir} scratch dir. Allowed kinds: fixture, run, store, assert, and service (a suite-wide background process started at that point in the sequence). A failing setup step errors every scenario.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        },
        "teardown": {
          "description": "Steps that always run after the last scenario, while suite services are still up (services stop last, LIFO). Failures are reported but never change the suite verdict.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },
    "runners": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/runner" }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "secrets": { "type": "array", "items": { "type": "string" } },
    "defaults": { "$ref": "#/$defs/defaults" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "stringOrList": {
      "description": "A contains/not_contains matcher argument: either a single substring, or a non-empty list of substrings that must all be present (contains) or all be absent (not_contains). The whole list counts as one matcher.",
      "oneOf": [
        { "type": "string" },
        { "type": "array", "minItems": 1, "items": { "type": "string" } }
      ]
    },
    "defaults": {
      "type": "object",
      "description": "Spec-wide default fragments merged into every matching element at load time (#39). Authoring sugar only: an explicit value always wins, maps shallow-merge, and a boolean default is OR-ed in. Not a macro/include system.",
      "additionalProperties": false,
      "properties": {
        "run": {
          "type": "object",
          "description": "Layered beneath every `run` step. `command` and `retry` are per-step and rejected here.",
          "additionalProperties": false,
          "properties": {
            "runner": { "type": "string" },
            "shell": { "type": "boolean" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" },
            "env": { "type": "object", "additionalProperties": { "type": "string" } },
            "clear_env": { "type": "boolean", "description": "Start the child from an empty environment instead of inheriting the host environment (#16). On Windows a small system-critical set (SystemRoot, SystemDrive, TEMP, TMP, PATHEXT) is always retained." },
            "pass_env": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Host variables copied into the cleared environment (#16). Requires clear_env: true; unset host variables are skipped." },
            "stdin": { "type": "string" }
          }
        },
        "scenario": {
          "type": "object",
          "description": "Scenario-level defaults. Only `env` is supported; it shallow-merges beneath each scenario's own env.",
          "additionalProperties": false,
          "properties": {
            "env": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        },
        "service": {
          "type": "object",
          "description": "Layered beneath every service. `name` and `command` identify a service and are rejected here; a whole `ready` probe is copied in when a service declares none.",
          "additionalProperties": false,
          "properties": {
            "shell": { "type": "boolean" },
            "cwd": { "type": "string" },
            "env": { "type": "object", "additionalProperties": { "type": "string" } },
            "clear_env": { "type": "boolean", "description": "Start the child from an empty environment instead of inheriting the host environment (#16). On Windows a small system-critical set (SystemRoot, SystemDrive, TEMP, TMP, PATHEXT) is always retained." },
            "pass_env": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Host variables copied into the cleared environment (#16). Requires clear_env: true; unset host variables are skipped." },
            "ready": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "file": { "type": "string" },
                "port": { "type": "string" },
                "log": { "type": "string" },
                "delay": { "type": "string" },
                "timeout": { "type": "string" },
                "store": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "runner": {
      "type": "object",
      "required": ["type"],
      "description": "A runner is discriminated by `type`: only the fields for that type are allowed, so cross-type fields are rejected and editors can narrow completion (#44).",
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "cmd" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" }
          }
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "http" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" },
            "base_url": { "type": "string" }
          }
        },
        {
          "required": ["dsn"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "db" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" },
            "dsn": { "type": "string" },
            "driver": { "enum": ["sqlite", "sqlite3", "postgres", "postgresql", "mysql"] }
          }
        },
        {
          "required": ["host", "user"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "ssh" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" },
            "host": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "key_file": { "type": "string" },
            "known_hosts": { "type": "string" },
            "insecure_host_key": { "type": "boolean" }
          }
        },
        {
          "required": ["target"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "grpc" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" },
            "target": { "type": "string" },
            "tls": { "type": "boolean" }
          }
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "browser" },
            "cwd": { "type": "string" },
            "timeout": { "type": "string" },
            "headless": { "type": "boolean", "description": "Run Chrome without a visible window (default true); set false to debug headed." },
            "exec_path": { "type": "string", "description": "Path to a specific Chrome/Chromium binary instead of the one discovered on PATH." },
            "browser_args": { "type": "array", "items": { "type": "string" }, "description": "Extra Chrome launch flags (bare names, no leading '--'), e.g. 'disable-gpu' or 'window-size=1280,720'." }
          }
        }
      ]
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": { "enum": ["linux", "darwin", "windows"] },
        "env": { "type": "string" },
        "command": { "type": "string" }
      }
    },
    "scenario": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "skip": { "$ref": "#/$defs/condition" },
        "only": { "$ref": "#/$defs/condition" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "matrix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": { "type": "string" }
          }
        },
        "services": {
          "type": "array",
          "items": { "$ref": "#/$defs/service" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        },
        "teardown": {
          "description": "Steps that always run after steps — pass, fail, error, or interrupt — sharing the scenario's variable store. For external side effects the isolated workdir cannot undo. A teardown failure is reported but does not change the scenario's verdict.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["name", "command"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "shell": { "type": "boolean" },
        "cwd": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "clear_env": { "type": "boolean", "description": "Start the child from an empty environment instead of inheriting the host environment (#16). On Windows a small system-critical set (SystemRoot, SystemDrive, TEMP, TMP, PATHEXT) is always retained." },
        "pass_env": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Host variables copied into the cleared environment (#16). Requires clear_env: true; unset host variables are skipped." },
        "ready": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": { "type": "string" },
            "port": { "type": "string" },
            "log": { "type": "string" },
            "delay": { "type": "string" },
            "timeout": { "type": "string" },
            "store": { "type": "string" }
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["fixture"] },
        { "required": ["run"] },
        { "required": ["http"] },
        { "required": ["query"] },
        { "required": ["grpc"] },
        { "required": ["cdp"] },
        { "required": ["assert"] },
        { "required": ["store"] },
        { "required": ["service"] },
        { "required": ["pty"] }
      ],
      "properties": {
        "fixture": { "$ref": "#/$defs/fixture" },
        "run": { "$ref": "#/$defs/run" },
        "http": { "$ref": "#/$defs/http" },
        "query": { "$ref": "#/$defs/query" },
        "grpc": { "$ref": "#/$defs/grpc" },
        "cdp": { "$ref": "#/$defs/cdp" },
        "service": {
          "$ref": "#/$defs/service",
          "description": "Starts a suite-wide background process at this point in the sequence. Valid only inside suite.setup; the loader rejects it anywhere else."
        },
        "pty": { "$ref": "#/$defs/pty" },
        "assert": { "$ref": "#/$defs/assert" },
        "store": { "$ref": "#/$defs/store" }
      }
    },
    "cdp": {
      "type": "object",
      "required": ["runner", "actions"],
      "additionalProperties": false,
      "properties": {
        "runner": { "type": "string", "minLength": 1 },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "navigate": { "type": "string" },
              "wait_visible": { "type": "string" },
              "wait_hidden": { "type": "string" },
              "click": { "type": "string" },
              "check": { "type": "string" },
              "uncheck": { "type": "string" },
              "text": { "type": "string" },
              "title": { "type": "boolean" },
              "eval": { "type": "string" },
              "send_keys": {
                "type": "object",
                "required": ["selector", "value"],
                "additionalProperties": false,
                "properties": {
                  "selector": { "type": "string" },
                  "value": { "type": "string" }
                }
              },
              "press": {
                "type": "object",
                "required": ["selector", "key"],
                "additionalProperties": false,
                "properties": {
                  "selector": { "type": "string" },
                  "key": { "type": "string" }
                }
              },
              "select": {
                "type": "object",
                "required": ["selector", "value"],
                "additionalProperties": false,
                "properties": {
                  "selector": { "type": "string" },
                  "value": { "type": "string" }
                }
              },
              "screenshot": {
                "type": "object",
                "required": ["path"],
                "additionalProperties": false,
                "properties": {
                  "path": { "type": "string" },
                  "selector": { "type": "string" }
                }
              },
              "attribute": {
                "type": "object",
                "required": ["selector", "name"],
                "additionalProperties": false,
                "properties": {
                  "selector": { "type": "string" },
                  "name": { "type": "string" }
                }
              },
              "upload": {
                "type": "object",
                "required": ["selector", "file"],
                "additionalProperties": false,
                "properties": {
                  "selector": { "type": "string" },
                  "file": { "type": "string" }
                }
              },
              "download": {
                "type": "object",
                "required": ["click"],
                "additionalProperties": false,
                "properties": {
                  "click": { "type": "string" },
                  "dir": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "query": {
      "type": "object",
      "required": ["runner", "sql"],
      "additionalProperties": false,
      "properties": {
        "runner": { "type": "string", "minLength": 1 },
        "sql": { "type": "string", "minLength": 1 }
      }
    },
    "grpc": {
      "type": "object",
      "required": ["runner", "method"],
      "additionalProperties": false,
      "properties": {
        "runner": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "header": { "type": "object", "additionalProperties": { "type": "string" } },
        "json": true
      }
    },
    "fixture": {
      "type": "object",
      "required": ["file"],
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "base64": { "type": "string" },
        "from": { "type": "string" },
        "symlink": { "type": "string" },
        "mode": { "type": "string", "pattern": "^[0-7]{3,4}$" },
        "mtime": { "type": "string" }
      }
    },
    "run": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "runner": { "type": "string" },
        "shell": { "type": "boolean" },
        "cwd": { "type": "string" },
        "timeout": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "clear_env": { "type": "boolean", "description": "Start the child from an empty environment instead of inheriting the host environment (#16). On Windows a small system-critical set (SystemRoot, SystemDrive, TEMP, TMP, PATHEXT) is always retained." },
        "pass_env": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Host variables copied into the cleared environment (#16). Requires clear_env: true; unset host variables are skipped." },
        "stdin": { "type": "string" },
        "stdout_to": { "type": "string", "minLength": 1, "description": "Write the command's captured stdout to this workdir-relative file (create/truncate), without needing shell redirection." },
        "stderr_to": { "type": "string", "minLength": 1, "description": "Write the command's captured stderr to this workdir-relative file (create/truncate), without needing shell redirection." },
        "retry": { "$ref": "#/$defs/retry" }
      }
    },
    "retry": {
      "type": "object",
      "required": ["times", "until"],
      "additionalProperties": false,
      "properties": {
        "times": { "type": "integer", "minimum": 1 },
        "interval": { "type": "string" },
        "until": { "$ref": "#/$defs/assert" }
      }
    },
    "pty": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "description": "Runs one command inside a real pseudo-terminal and drives it with a declarative expect/send session (#8) — for CLIs that branch on TTY-ness or present interactive prompts. POSIX-only at runtime; Windows reports a clear execution error.",
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "shell": { "type": "boolean" },
        "cwd": { "type": "string" },
        "rows": { "type": "integer", "minimum": 0 },
        "cols": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "string", "description": "Go duration bounding the WHOLE session (default 30s)." },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "clear_env": { "type": "boolean", "description": "Start the child from an empty environment instead of inheriting the host environment (#16). On Windows a small system-critical set (SystemRoot, SystemDrive, TEMP, TMP, PATHEXT) is always retained." },
        "pass_env": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Host variables copied into the cleared environment (#16). Requires clear_env: true; unset host variables are skipped." },
        "session": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "description": "Exactly one of expect (wait until the transcript matches the regexp) or send (write to the terminal; \"\" sends EOF/^D).",
            "properties": {
              "expect": { "type": "string" },
              "send": { "type": "string" }
            }
          }
        }
      }
    },
    "http": {
      "type": "object",
      "required": ["method"],
      "additionalProperties": false,
      "properties": {
        "runner": { "type": "string" },
        "method": { "type": "string" },
        "path": { "type": "string" },
        "header": { "type": "object", "additionalProperties": { "type": "string" } },
        "json": true,
        "body": { "type": "string", "description": "Raw string payload sent verbatim (default Content-Type text/plain). The payload fields (json/body/body_file/form+files) are mutually exclusive." },
        "body_file": { "type": "string", "minLength": 1, "description": "Workdir-relative file streamed as the raw request body (binary-safe) — for upload endpoints that take file content directly." },
        "form": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Form fields: application/x-www-form-urlencoded alone, multipart/form-data when files is also set." },
        "files": {
          "type": "array",
          "minItems": 1,
          "description": "Files attached as multipart/form-data parts (the browser-style upload most web apps expect).",
          "items": {
            "type": "object",
            "required": ["field", "path"],
            "additionalProperties": false,
            "properties": {
              "field": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "content_type": { "type": "string" }
            }
          }
        },
        "body_to": { "type": "string", "minLength": 1, "description": "Write the response body to this workdir-relative file, so file/image/pdf assertions can inspect a download (the http analogue of run's stdout_to)." },
        "follow_redirects": { "type": "boolean", "description": "Follow 3xx responses (default true). Set false to assert on the redirect itself: its status code and Location header." },
        "retry": { "$ref": "#/$defs/retry" }
      },
      "allOf": [
        { "not": { "required": ["json", "body"] } },
        { "not": { "required": ["json", "body_file"] } },
        { "not": { "required": ["json", "form"] } },
        { "not": { "required": ["json", "files"] } },
        { "not": { "required": ["body", "body_file"] } },
        { "not": { "required": ["body", "form"] } },
        { "not": { "required": ["body", "files"] } },
        { "not": { "required": ["body_file", "form"] } },
        { "not": { "required": ["body_file", "files"] } }
      ]
    },
    "assert": {
      "type": "object",
      "additionalProperties": false,
      "description": "An assert sets one or more target families; each is an independent check and all must hold (e.g. exit_code + stdout + file in one block).",
      "anyOf": [
        { "required": ["exit_code"] },
        { "required": ["stdout"] },
        { "required": ["stderr"] },
        { "required": ["file"] },
        { "required": ["status"] },
        { "required": ["header"] },
        { "required": ["body"] },
        { "required": ["rows"] },
        { "required": ["grpc_status"] },
        { "required": ["message"] },
        { "required": ["value"] },
        { "required": ["image"] },
        { "required": ["dir"] },
        { "required": ["pdf"] }
      ],
      "properties": {
        "exit_code": { "$ref": "#/$defs/exitCode" },
        "stdout": { "$ref": "#/$defs/stream" },
        "stderr": { "$ref": "#/$defs/stream" },
        "file": { "$ref": "#/$defs/file" },
        "status": { "type": "integer" },
        "header": { "$ref": "#/$defs/headerMatch" },
        "body": { "$ref": "#/$defs/stream" },
        "rows": { "$ref": "#/$defs/stream" },
        "grpc_status": { "type": "integer" },
        "message": { "$ref": "#/$defs/stream" },
        "value": { "$ref": "#/$defs/stream" },
        "image": { "$ref": "#/$defs/image" },
        "dir": { "$ref": "#/$defs/dir" },
        "pdf": { "$ref": "#/$defs/pdf" }
      }
    },
    "pdf": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "pages": { "type": "integer", "minimum": 0 },
        "min_pages": { "type": "integer", "minimum": 0 },
        "max_pages": { "type": "integer", "minimum": 0 },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "text": { "$ref": "#/$defs/stream" }
      }
    },
    "dir": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" },
        "contains": { "type": "array", "items": { "type": "string" } },
        "not_contains": { "type": "array", "items": { "type": "string" } },
        "count": { "type": "integer", "minimum": 0 },
        "min_count": { "type": "integer", "minimum": 0 },
        "max_count": { "type": "integer", "minimum": 0 },
        "glob": { "type": "string" }
      }
    },
    "exitCode": {
      "oneOf": [
        { "type": "integer" },
        {
          "type": "object",
          "required": ["not"],
          "additionalProperties": false,
          "properties": { "not": { "type": "integer" } }
        }
      ]
    },
    "stream": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["empty"] },
        { "required": ["contains"] },
        { "required": ["not_contains"] },
        { "required": ["matches"] },
        { "required": ["not_matches"] },
        { "required": ["equals"] },
        { "required": ["not_equals"] },
        { "required": ["json"] },
        { "required": ["yaml"] },
        { "required": ["snapshot"] }
      ],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "empty": { "type": "boolean" },
        "contains": { "$ref": "#/$defs/stringOrList" },
        "not_contains": { "$ref": "#/$defs/stringOrList" },
        "matches": { "type": "string" },
        "not_matches": { "type": "string" },
        "equals": { "type": "string" },
        "not_equals": { "type": "string" },
        "json": { "$ref": "#/$defs/jsonAssert" },
        "yaml": { "$ref": "#/$defs/jsonAssert" },
        "snapshot": { "type": "string" }
      }
    },
    "file": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["exists"] },
        { "required": ["contains"] },
        { "required": ["not_contains"] },
        { "required": ["executable"] },
        { "required": ["json"] },
        { "required": ["snapshot"] }
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" },
        "contains": { "$ref": "#/$defs/stringOrList" },
        "not_contains": { "$ref": "#/$defs/stringOrList" },
        "executable": { "type": "boolean" },
        "json": { "$ref": "#/$defs/jsonAssert" },
        "snapshot": { "type": "string" }
      }
    },
    "image": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "anyOf": [
        { "required": ["format"] },
        { "required": ["width"] },
        { "required": ["height"] },
        { "required": ["min_width"] },
        { "required": ["max_width"] },
        { "required": ["min_height"] },
        { "required": ["max_height"] },
        { "required": ["alpha"] },
        { "required": ["similar_to"] }
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "format": { "enum": ["png", "jpeg", "gif", "webp", "bmp", "tiff", "avif", "svg"] },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 },
        "min_width": { "type": "integer", "minimum": 0 },
        "max_width": { "type": "integer", "minimum": 0 },
        "min_height": { "type": "integer", "minimum": 0 },
        "max_height": { "type": "integer", "minimum": 0 },
        "alpha": { "type": "boolean" },
        "similar_to": { "type": "string", "minLength": 1 },
        "max_diff": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "jsonAssert": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["equals"] },
        { "required": ["matches"] },
        { "required": ["length"] },
        { "required": ["gt"] },
        { "required": ["gte"] },
        { "required": ["lt"] },
        { "required": ["lte"] }
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "equals": true,
        "matches": { "type": "string" },
        "length": { "type": "integer" },
        "gt": { "type": "number" },
        "gte": { "type": "number" },
        "lt": { "type": "number" },
        "lte": { "type": "number" }
      }
    },
    "headerMatch": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["contains"] },
        { "required": ["equals"] }
      ],
      "properties": {
        "name": { "type": "string" },
        "contains": { "type": "string" },
        "equals": { "type": "string" }
      }
    },
    "store": {
      "type": "object",
      "required": ["name", "from"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "from": {
          "type": "object",
          "additionalProperties": false,
          "oneOf": [
            { "required": ["stdout"] },
            { "required": ["body"] },
            { "required": ["file"] },
            { "required": ["header"] },
            { "required": ["rows"] },
            { "required": ["message"] },
            { "required": ["value"] }
          ],
          "properties": {
            "stdout": { "$ref": "#/$defs/stream" },
            "body": { "$ref": "#/$defs/stream" },
            "file": { "$ref": "#/$defs/file" },
            "header": { "type": "string" },
            "rows": { "$ref": "#/$defs/stream" },
            "message": { "$ref": "#/$defs/stream" },
            "value": { "$ref": "#/$defs/stream" }
          }
        }
      }
    }
  }
}
